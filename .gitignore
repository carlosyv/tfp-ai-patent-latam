# =============================================================================
# .gitignore — tfp-ai-patent-latam
# =============================================================================
# Publication replication package for:
# "The Impact of AI Adoption on Total Factor Productivity (TFP) in Latin America"
# =============================================================================

# ------------------------------------------------------------------------------
# Python artifacts
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.so

# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------------------------
# OS metadata
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# IDE / editor files
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Archive — legacy pipeline variants (pre-v4)
# These are internal development history, not part of the publication package.
# ------------------------------------------------------------------------------
archive/

# ------------------------------------------------------------------------------
# Data — large uncompressed file (keep .gz version only)
# ------------------------------------------------------------------------------
data/EMP_TEMP_SEX_AGE_NB_A-20260325T1614.csv

# ------------------------------------------------------------------------------
# Output — exclude all pipeline variant outputs except the canonical v4_noimput
# ------------------------------------------------------------------------------
output/results/benchmark_dissertation_v3/
output/results/benchmark_dissertation_v3_noimput/
output/results/benchmark_dissertation_v4/
output/results/comparison_v3_vs_v3_noimput.xlsx
output/results/comparison_v3_vs_v4_noimput.xlsx
output/results/comparison_v4_vs_v4noimput.xlsx

# Intermediate merged datasets (regenerated by running the pipeline)
output/results/solow_tfp_dissertation_v3.csv
output/results/solow_tfp_dissertation_v3_noimput.csv
output/results/solow_tfp_dissertation_v4.csv
output/results/malmquist_dissertation_v3.csv
output/results/malmquist_dissertation_v3_noimput.csv
output/results/malmquist_dissertation_v4.csv
output/results/merged_dissertation_v3.csv
output/results/merged_dissertation_v3_noimput.csv
output/results/merged_dissertation_v4.csv

# H3 intermediate output (robustness, generated on demand)
output/h3_institutional_comparison/

# Jupyter notebooks (if any)
*.ipynb_checkpoints/
.ipynb_checkpoints/

# Logs
*.log
