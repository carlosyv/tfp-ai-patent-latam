# =============================================================================
# .gitignore — tfp-ai-patent-latam
# =============================================================================
# Publication replication package for:
# "The Impact of AI Adoption on Total Factor Productivity (TFP) in Latin America"
# =============================================================================

# ------------------------------------------------------------------------------
# Python artifacts
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.so

# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------------------------
# OS metadata
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# IDE / editor files
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Archive — legacy pipeline variants (pre-v5 internal development history,
# not part of the publication package)
# ------------------------------------------------------------------------------
archive/
output/results/archive/

# ------------------------------------------------------------------------------
# Data — large uncompressed ILOSTAT file. The pipeline reads the .gz directly,
# so the uncompressed CSV should never be committed.
# ------------------------------------------------------------------------------
data/EMP_TEMP_SEX_AGE_NB_A-20260325T1614.csv

# ------------------------------------------------------------------------------
# Legacy H3 robustness output (pre-v5, generated on demand)
# ------------------------------------------------------------------------------
output/h3_institutional_comparison/

# Jupyter notebooks (if any)
*.ipynb_checkpoints/
.ipynb_checkpoints/

# Logs
*.log
